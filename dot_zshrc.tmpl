# direnv
useenv() {
  export ENV="$1"
  direnv reload
  echo "Switched to environment: $ENV"
}

parse_env() {
  case "$ENV" in
    |local)
      echo "%F{black}[local]%f "
      ;;
    dev)
      echo "%K{blue}%F{black}[dev]%f%k "
      ;;
    staging)
      echo "%K{yellow}%F{black}[staging]%f%k "
      ;;
    prod)
      echo "%K{red}%F{white}[PROD]%f%k "
      ;;
    *)
      echo "%K{black}%F{white}[$APP_ENV]%f%k "
      ;;
  esac
}

PROMPT='$(parse_env)'$PROMPT

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew (macOS)
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
{{- else -}}
# Homebrew (Linux)
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{- end }}
